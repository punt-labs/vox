(SDEF 252
  (SHEAD 252
    "Unmute"
    ())
  (BODY 253
    (LIST
      (SDECL 253
        (SREF 253 "\Delta VoxState" "" () ()))
      (DECL 254
        (LIST
          (NAME "v" "?"))
        (POWER 254
          (REF 254 (NAME "VOICE" "") ()))))
    (LIST
      (INREL 256
        (NAME "\leq" "")
        (APPLY 256
          (REF 256 (NAME "\#" "") ())
