(SDEF 83
  (SHEAD 83
    "VoxState"
    ())
  (BODY 84
    (LIST
      (DECL 84
        (LIST
          (NAME "notify" ""))
        (REF 84 (NAME "NotifyMode" "") ()))
      (DECL 85
        (LIST
          (NAME "speak" ""))
        (REF 85 (NAME "SpeakMode" "") ()))
      (DECL 86
        (LIST
          (NAME "voice" ""))
        (POWER 86
          (REF 86 (NAME "VOICE" "") ()))))
    (LIST
      (INREL 88
        (NAME "\leq" "")
        (APPLY 88
          (REF 88 (NAME "\#" "") ())
          (REF 88 (NAME "voice" "") ()))
        (NUMBER 88 "1")))))

(SDEF 98
