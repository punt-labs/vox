{
  "name": "vox-dev",
  "description": "Text-to-speech for Claude Code: /unmute, /mute, /vibe, /recap",
  "version": "1.9.1",
  "author": {
    "name": "Punt Labs",
    "email": "hello@punt-labs.com"
  },
  "mcpServers": {
    "mic": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-c",
        "if command -v mcp-proxy >/dev/null 2>&1; then exec mcp-proxy ws://localhost:8421/mcp; else exec vox mcp; fi"
      ]
    }
  }
}
